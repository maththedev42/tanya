# DeepSeek is the default provider.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
TANYA_MODEL=deepseek-v4-pro

# Profile: "chat" (default) uses deepseek-v4-pro with 90s timeout.
# "reasoner" switches to deepseek-reasoner with 180s timeout.
# TANYA_PROFILE=reasoner

# Override timeout in ms (overrides profile default).
# TANYA_TIMEOUT_MS=180000

# Generic OpenAI-compatible provider support.
# TANYA_PROVIDER=custom
# TANYA_API_KEY=
# TANYA_BASE_URL=https://provider.example.com
# TANYA_MODEL=provider-model-name


# ── Agent run behavior ────────────────────────────────────────

# Permission mode override: safe | auto | bypass. Unset = per-command default.
# TANYA_MODE=

# Interactive soft turn budget override; unset = adaptive. Shifts where stall detection begins.
# TANYA_MAX_TURNS=

# Absolute turn ceiling for extended runs. Unset = unbounded (progress-based stops only).
# TANYA_HARD_TURN_CEILING=

# Prompt-token backstop for stalled runs (no progress 2+ turns). 0|off disables.
# TANYA_MAX_STALL_TOKENS=1500000

# Serve: automatic continue budget after a stall stop. 0|off disables.
# TANYA_AUTO_CONTINUE=2

# Fraction of the context window reserved for the prompt-side budget.
# TANYA_PROMPT_BUDGET_RATIO=0.25

# Slim system prompt (drops heavyweight sections) for small-context providers.
# TANYA_LITE_PROMPT=1

# Max model-escalation hops per run (min 0).
# TANYA_ESCALATION_CAP=5

# Per-turn reasoning-token budget for planning/tool-call steps (min 1).
# TANYA_REASONING_CAP_SHORT=2000

# Per-turn reasoning-token budget for synthesis/verification steps (min 1).
# TANYA_REASONING_CAP_LONG=8000

# Mutations before the first build-verification nudge.
# TANYA_FIRST_BUILD_NUDGE_AFTER=3

# Flush a RUN_IN_PROGRESS heartbeat every N mutations (kill -9 evidence).
# TANYA_SENTINEL_FLUSH_EVERY=8

# ── Quality gates ─────────────────────────────────────────────

# Interactive task-completion gates (spec coverage, verify, commit).
# TANYA_TASK_GATES=off

# Runtime definition-of-done gate for behavioral criteria in coding prompts.
# TANYA_DOD_GATE=off

# Recovery preflight (doctor + RECOVERY block) after a FAILed run.
# TANYA_RECOVERY=off

# Read-only drift guard: nudges then wraps up coding runs that never edit.
# TANYA_DRIFT_GUARD=off

# Turn snapshots: side-repo snapshot of the touched repo before a turn's first mutating tool (tanya restore).
# TANYA_SNAPSHOTS=off

# Unified stuck guard: fingerprint repeated identical failures (incl. re-spelled commands), warn then wrap up.
# TANYA_STUCK_GUARD=off

# Override the side-repo snapshot store (default ~/.tanya/snapshots).
# TANYA_SNAPSHOTS_DIR=

# Include model reasoning in verifier transcripts.
# TANYA_VERIFIER_INCLUDE_REASONING=1

# Shell used by verify commands (path or name).
# TANYA_VERIFIER_SHELL=

# Runtime boot verification for generated apps.
# TANYA_RUNTIME_CHECK=1

# Tier-1 runtime verification profile.
# TANYA_TIER1=1

# ── Subagents & subtasks ──────────────────────────────────────

# Max concurrent subagent jobs.
# TANYA_SUBAGENT_CONCURRENCY=3

# Max parallel subtasks (min 1).
# TANYA_SUBTASK_MAX_PARALLEL=3

# Max subtask nesting depth.
# TANYA_SUBTASK_MAX_DEPTH=2

# Detect and refuse cyclic subtask graphs.
# TANYA_SUBTASK_CYCLE_CHECK=off

# ── Context / repo map ────────────────────────────────────────

# Token budget for the repo map in the system prompt.
# TANYA_REPO_MAP_PROMPT_BUDGET=1000

# Skip files larger than this when building the repo map.
# TANYA_REPO_MAP_MAX_FILE_BYTES=

# ── Providers & routing ───────────────────────────────────────

# Context-window safety factor for route resolution.
# TANYA_ROUTE_SAFETY_FACTOR=0.85

# Max concurrent provider requests.
# TANYA_PROVIDER_CONCURRENCY=

# Silence provider deprecation warnings (=1).
# TANYA_SUPPRESS_DEPRECATION=1

# Verbose provider debug logging.
# TANYA_DEBUG=1

# Default external backend for run routing (claude | codex | ...).
# TANYA_BACKEND=

# ── UI & serve ────────────────────────────────────────────────

# Force the TUI renderer.
# TANYA_TUI=1

# Hide streamed reasoning in the human sink.
# TANYA_HIDE_REASONING=1

# Live status line during runs.
# TANYA_LIVE_STATUS=off

# Model for UI/companion calls (falls back to the main model).
# TANYA_UI_MODEL=

# Base URL for UI/companion calls.
# TANYA_UI_BASE_URL=

# API key for UI/companion calls.
# TANYA_UI_API_KEY=

# ── Tools ─────────────────────────────────────────────────────

# Throttle for streamed tool progress events.
# TANYA_PROGRESS_THROTTLE_MS=

# Timeout per MCP tool call (min 1000).
# TANYA_MCP_CALL_TIMEOUT_MS=30000

# Chrome/Chromium binary for video tools.
# TANYA_CHROME_PATH=

# ffmpeg binary for video/ad tools.
# TANYA_FFMPEG_PATH=

# ── Memory & pricing ──────────────────────────────────────────

# Override for the cross-session repair-memory home directory.
# TANYA_MEMORY_HOME=

# Obsidian vault path — completed tasks are appended to daily notes.
# TANYA_OBSIDIAN_VAULT=

# Override input price per Mtok for cost estimates.
# TANYA_PRICE_INPUT_PER_MTOK=

# Override output price per Mtok for cost estimates.
# TANYA_PRICE_OUTPUT_PER_MTOK=

# Override cache-hit price per Mtok for cost estimates.
# TANYA_PRICE_CACHE_HIT_PER_MTOK=

# ── Maintenance ───────────────────────────────────────────────

# Automatic workspace hygiene (stale artifacts, temp dirs).
# TANYA_AUTO_CLEAN=off

# Refuse heavy work when free disk is below the minimum.
# TANYA_DISK_GUARD=off

# Minimum free disk (GB) for the disk guard.
# TANYA_DISK_MIN_GB=

# Reap orphaned helper daemons during hygiene runs.
# TANYA_REAP_DAEMONS=off

# ── Sessions ──────────────────────────────────────────────────

# Record run sessions for the session browser.
# TANYA_RUN_SESSIONS=1

# ── Eval ──────────────────────────────────────────────────────

# Parallelism for eval suite runs.
# TANYA_EVAL_PARALLEL=

# Per-task timeout for eval runs.
# TANYA_EVAL_TASK_TIMEOUT_MS=

# Per-task token cap for eval runs.
# TANYA_EVAL_TASK_TOKEN_CAP=

# ── Integrations ──────────────────────────────────────────────

# Override the integrations discovery directory.
# TANYA_INTEGRATIONS_DIR=

# CosmoChat integration base URL.
# TANYA_COSMOCHAT_BASE_URL=

# Grace period before finalizing a CosmoChat message.
# TANYA_COSMOCHAT_MESSAGE_END_GRACE_MS=
